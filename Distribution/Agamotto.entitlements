<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Reference entitlements for the eventual Developer ID app bundle (Phase 5).
    Not used by the SwiftPM spike build.

    Hardened Runtime + microphone access. Screen Recording is a runtime TCC grant,
    NOT an entitlement, so it does not appear here.
  -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
