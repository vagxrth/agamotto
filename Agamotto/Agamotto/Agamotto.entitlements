<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened Runtime + microphone. Screen Recording is a runtime TCC grant, not an entitlement.
	     App Sandbox stays OFF (Developer ID distribution, not Mac App Store). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
